# ----------------------------------------------------------
# FIND BEST WORD MATCH
# ----------------------------------------------------------

def find_best_match(word):

    best_word = None
    best_score = 0

    for category in brain:

        for known_word in brain[category]:

            score = similarity(
                word,
                known_word
            )

            if score > best_score:

                best_score = score
                best_word = (
                    category,
                    known_word
                )

    return best_word, best_score



# ----------------------------------------------------------
# CHECK NEGATION
# ----------------------------------------------------------

def has_negation(words, index):

    start = max(
        0,
        index - 2
    )

    nearby_words = words[start:index]


    for word in nearby_words:

        if word in NEGATIONS:

            return True


    return False



# ----------------------------------------------------------
# PREDICTION SYSTEM
# ----------------------------------------------------------

def predict(text):

    words = clean_text(text)


    scores = {}


    for category in brain:

        scores[category]=0



    matched_words=[]


    for index,word in enumerate(words):


        result,confidence=find_best_match(word)


        if result is None:

            continue



        category,known_word=result



        # Ignore very bad matches

        if confidence < 0.65:

            continue



        power = brain[category][known_word]



        # If negative word detected before
        # change meaning

        if has_negation(words,index):


            if category=="positive":

                category="negative"


            elif category=="negative":

                category="positive"



        scores[category]+=power*confidence


        matched_words.append(
            (
                word,
                known_word,
                category,
                round(confidence,2)
            )
        )



    total=sum(scores.values())


    if total==0:


        return {

            "prediction":"Unknown",
            "confidence":0,
            "scores":scores,
            "matches":matched_words

        }



    best_category=max(
        scores,
        key=scores.get
    )


    confidence=(

        scores[best_category]
        /
        total

    )*100



    return {


        "prediction":
            best_category.capitalize(),


        "confidence":
            round(confidence,2),


        "scores":
            scores,


        "matches":
            matched_words


    }



# ----------------------------------------------------------
# LEARNING SYSTEM
# ----------------------------------------------------------

def learn_word(word,category,weight=2):


    word=word.lower()



    if category not in brain:

        brain[category]={}



    if word in brain[category]:

        brain[category][word]+=weight


    else:

        brain[category][word]=weight


    stats["learned_words"]+=1


    save_brain(brain)
    save_stats()



# ----------------------------------------------------------
# AI SELF CHECK
# ----------------------------------------------------------

def self_check(result):


    confidence=result["confidence"]



    if confidence>=80:

        return "I am very confident."


    elif confidence>=60:

        return "I am moderately confident."


    elif confidence>0:

        return "I am not completely sure."


    else:

        return "I don't know yet."



