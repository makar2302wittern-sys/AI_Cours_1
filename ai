def clean_text(text):

    text=text.lower()

    text=re.sub(r"[^a-zA-Z\s'?]"," ",text)

    text=text.replace("n't","nt")

    words=text.split()

    return words

SIMILARITY_CACHE = {}

def similarity(word1, word2):

    key = (word1, word2)

    if key in SIMILARITY_CACHE:
        return SIMILARITY_CACHE[key]

    score = SequenceMatcher(
        None,
        word1,
        word2
    ).ratio()

    SIMILARITY_CACHE[key] = score

    return score

