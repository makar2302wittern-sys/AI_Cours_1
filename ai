# ==========================================================
# TEXT FUNCTIONS
# ==========================================================

def clean_text(text):

    text=text.lower()

    text=re.sub(r"[^a-zA-Z\s']"," ",text)

    text=text.replace("n't","nt")

    words=text.split()

    return words


def similarity(word1,word2):

    return SequenceMatcher(
        None,
        word1,
        word2
    ).ratio()

