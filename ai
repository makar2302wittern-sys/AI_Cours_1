def ask_feedback():

    if not last_result_cache:
        return

    if last_result_cache["prediction"] == "Unknown":
        return

    ans = input("\nAI: Was my answer correct? (+ / - / skip): ").strip().lower()

    if ans == "+":

        stats["correct_predictions"] += 1

        print("AI: Great! Thanks for confirming.")

        save_stats()
        return


    if ans != "-":

        save_stats()
        return


    stats["wrong_predictions"] += 1

    print("\nAI: I was wrong.")

    print("\nChoose the correct category:\n")

    categories = list(brain.keys())

    for i, cat in enumerate(categories, 1):
        print(f"{i}. {cat}")

    choice = input("\nCategory number (Enter = skip): ").strip()

    if not choice.isdigit():

        save_stats()
        return

    idx = int(choice) - 1

    if idx < 0 or idx >= len(categories):

        save_stats()
        return

    correct_category = categories[idx]

    changed = False

    for match in last_result_cache["matches"]:

        word, known_word, matched_cat, confidence = match

        # ---------- уменьшить неправильный вес ----------

        if known_word in brain.get(matched_cat, {}):

            brain[matched_cat][known_word] = max(
                1,
                brain[matched_cat][known_word] - 1
            )

        # ---------- увеличить правильный ----------

        if correct_category not in brain:

            brain[correct_category] = {}

        if known_word in brain[correct_category]:

            brain[correct_category][known_word] += 2

        else:

            brain[correct_category][known_word] = 3

        changed = True

    # ---------- неизвестные слова ----------

    for word in last_result_cache["unknown_words"]:

        if len(word) <= 2:
            continue

        if word in brain[correct_category]:

            brain[correct_category][word] += 2

        else:

            brain[correct_category][word] = 2

        changed = True

    if changed:

        rebuild_index()

        save_brain(brain)

        print("\nAI: Knowledge updated successfully.")

    save_stats()



