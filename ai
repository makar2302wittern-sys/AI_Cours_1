# ----------------------------------------------------------
# FIND BEST WORD MATCH
# ----------------------------------------------------------

def find_best_match(word):

    # ---------- FAST EXACT SEARCH ----------

    if word in word_index:

        category, weight = word_index[word]

        return (category, word), 1.0

    # ---------- FUZZY SEARCH ----------

    best_word = None
    best_score = 0

    word_len = len(word)

    for category in brain:

        if not isinstance(brain[category], dict):
            continue

        for known_word in brain[category]:

            # пропускаем слишком разные слова
            if abs(len(known_word) - word_len) > 3:
                continue

            score = similarity(
                word,
                known_word
            )

            if score > best_score:

                best_score = score

                best_word = (
                    category,
                    known_word
                )

    return best_word, best_score



# ----------------------------------------------------------
# CHECK NEGATION
# ----------------------------------------------------------

def has_negation(words, index):

    start = max(
        0,
        index - 3
    )

    nearby_words = words[start:index]


    for word in nearby_words:

        if word in NEGATIONS:

            return True


    return False



# ----------------------------------------------------------
# PREDICTION SYSTEM
# ----------------------------------------------------------

def predict(text):

    global context_history, last_result_cache

    words = clean_text(text)


    scores = {}


    for category in brain:

        scores[category]=0



    matched_words=[]
    unknown_words=[]
    
    has_question_mark = "?" in text


    for index, word in enumerate(words):

        if word == "?":
            continue

        if word in STOP_WORDS:
            continue

        if word in INTENSIFIERS:
            continue


        result,confidence=find_best_match(word)


        if result is None or confidence < 0.65:

            unknown_words.append(word)
            continue



        category,known_word=result



        power = brain[category][known_word]


        # усиление слова

        if index > 0:

            previous_word = words[index-1]

            if previous_word in INTENSIFIERS:

                power *= INTENSIFIERS[previous_word]



        if has_negation(words,index):


            if category=="positive":

                category="negative"


            elif category=="negative":

                category="positive"



        scores[category]+=power*confidence


        matched_words.append(
            (
                word,
                known_word,
                category,
                round(confidence,2)
            )
        )



    total=sum(scores.values())


    if total==0 and not has_question_mark:


        res = {

            "prediction":"Unknown",
            "confidence":0,
            "scores":scores,
            "matches":matched_words,
            "unknown_words":unknown_words,
            "intent": "Unknown",
            "emotion": "Unknown",
            "topic": "Unknown",
            "context": "None"

        }
        last_result_cache = res
        return res



    best_category = max(
        scores,
        key=scores.get
    )


    sorted_scores = sorted(
        scores.values(),
        reverse=True
    )


    top_score = sorted_scores[0] if sorted_scores else 0


    second_score = (
        sorted_scores[1]
        if len(sorted_scores) > 1
        else 0
    )


    difference = top_score - second_score


    confidence = min(
        100,
        (difference / (top_score + 1)) * 100
    )


    if confidence < 5:

        best_category = "Unknown"


    intent = "Question" if best_category == "question" or has_question_mark else "Statement"
    if best_category == "greeting": intent = "Greeting"

    emotion = "Neutral"
    if best_category == "positive": emotion = "Positive"
    elif best_category == "negative": emotion = "Negative"

    topic_scores = {k: v for k, v in scores.items() if k.startswith("topic_") or k == "custom_categories"}
    best_topic = max(topic_scores, key=topic_scores.get) if sum(topic_scores.values()) > 0 else "General"

    context = "No context"
    if len(context_history) > 0:
        context = f"Previous topic: {context_history[-1].replace('topic_', '')}"

    if best_topic != "General":
        context_history.append(best_topic)
        if len(context_history) > 3:
            context_history.pop(0)


    result_dict = {


        "prediction":
            best_category.capitalize(),


        "confidence":
            round(confidence,2),


        "scores":
            scores,


        "matches":
            matched_words,


        "unknown_words":
            unknown_words,


        "intent":
            intent,


        "emotion":
            emotion,


        "topic":
            best_topic.replace("topic_", "").capitalize(),


        "context":
            context


    }


    last_result_cache = result_dict

    return result_dict



