# LEARNING SYSTEM
# ----------------------------------------------------------

def learn_word(word,category,weight=2):


    word=word.lower()



    if category not in brain:

        brain[category]={}



    if word in brain[category]:

        brain[category][word]+=weight


    else:

        brain[category][word]=weight


    stats["learned_words"]+=1


    save_brain(brain)
    save_stats()
    rebuild_index()



# ----------------------------------------------------------
# INTERACTIVE LEARNING FOR UNKNOWN WORDS (FIXED)
# ----------------------------------------------------------

def interactive_learning(unknown_words):

    for word in unknown_words:

        if len(word) <= 2: 
            continue

        ans = input(f"\nAI: I don't know the word '{word}'. Do you want to teach me? (yes/no): ").lower()

        if ans in ['yes', 'y']:

            print(f"Available categories: {list(brain.keys())}")
            category = input("Enter category name (existing or new): ").lower()

            try:
                weight = int(input("Enter weight from 1 to 5: "))
            except:
                weight = 2

            learn_word(word, category, weight)
            
            # Feature 6: Auto synonym linking
            for cat in brain:
                if cat == category:
                    continue
                for kw, pw in brain[cat].items():
                    if similarity(word, kw) >= 0.8:
                        brain[category][word] = pw
                        break

            print(f"AI learned: '{word}' as '{category}' with weight {weight}.")



