    else:
        scores = last_result_cache["scores"]
        sorted_scores = sorted(scores.items(), key=lambda item: item[1], reverse=True)
        
        alt_category = "unknown"
        if len(sorted_scores) > 1 and sorted_scores[1][1] > 0:
            alt_category = sorted_scores[1][0]

        print(f"AI: My confidence was only {conf}%.")
        print(f"AI: Re-evaluating... I might have made a mistake. Alternative category could be: '{alt_category.capitalize()}'.")



